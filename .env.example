# =============================================================================
# WhatToCook — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.

# Environment: development | staging | production
ENVIRONMENT=development

# =============================================================================
# Database
# =============================================================================
POSTGRES_USER=whattocook
POSTGRES_PASSWORD=whattocook_dev
POSTGRES_DB=whattocook
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://whattocook:whattocook_dev@localhost:5432/whattocook

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# JWT Auth
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_real_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_API_KEY=CHANGE_ME_generate_a_real_secret

# =============================================================================
# LLM Provider
# =============================================================================
# Options: local_vllm | gemini | mock
# Use "mock" for local development without a GPU or real LLM
LLM_PROVIDER=local_vllm

# Local vLLM (development)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL_NAME=gpt-oss-120b
VLLM_API_KEY=not-needed

# Gemini (production)
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-pro

# =============================================================================
# Embedding Provider
# =============================================================================
# Options: local_vllm | gemini | mock
# Use "mock" for local development without a GPU or real embedding model
EMBEDDING_PROVIDER=local_vllm

# Local vLLM embedding
VLLM_EMBEDDING_MODEL_NAME=text-embedding-model
VLLM_EMBEDDING_BASE_URL=http://localhost:8000/v1

# Gemini embedding
GEMINI_EMBEDDING_MODEL_NAME=text-embedding-004

# =============================================================================
# Image Generation (FLUX dev)
# =============================================================================
FLUX_WORKER_URL=http://localhost:8100

# =============================================================================
# OpenTelemetry
# =============================================================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=whattocook-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Frontend OpenTelemetry
VITE_OTEL_ENABLED=false
VITE_OTEL_EXPORTER_URL=http://localhost:4318/v1/traces

# =============================================================================
# Object Storage (MinIO / S3)
# =============================================================================
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=whattocook
S3_REGION=us-east-1
# Set to "true" for MinIO, "false" for real S3
S3_USE_PATH_STYLE=true

# =============================================================================
# MinIO Console (development only)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
